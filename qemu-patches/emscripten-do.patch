diff --git a/util/main-loop.c b/util/main-loop.c
index 797b640..b281b78 100644
--- a/util/main-loop.c
+++ b/util/main-loop.c
@@ -293,6 +293,60 @@ static void glib_pollfds_poll(void)
 
 #define MAX_MAIN_LOOP_SPIN (1000)
 
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+
+/*
+ * Emscripten main loop wait: use emscripten_sleep() so ASYNCIFY can
+ * suspend the main loop and return control to the JavaScript event loop.
+ * This allows the Durable Object to drive QEMU in a non-blocking manner.
+ *
+ * Before sleeping, we also drive one round of vCPU execution. In a normal
+ * QEMU build, the vCPU runs in a dedicated thread. In emscripten there is
+ * only one thread so we must interleave CPU execution with I/O polling.
+ */
+static int os_host_main_loop_wait(int64_t timeout)
+{
+    GMainContext *context = g_main_context_default();
+    int ret;
+    int timeout_ms;
+
+    g_main_context_acquire(context);
+    glib_pollfds_fill(&timeout);
+
+    qemu_mutex_unlock_iothread();
+    replay_mutex_unlock();
+
+    /* Convert ns timeout to ms, capping at 4ms for responsive DO scheduling */
+    if (timeout < 0) {
+        timeout_ms = 4;
+    } else if (timeout == 0) {
+        timeout_ms = 0;
+    } else {
+        timeout_ms = (int)(timeout / 1000000);
+        if (timeout_ms > 4) timeout_ms = 4;
+    }
+
+    /*
+     * emscripten_sleep uses ASYNCIFY to unwind the WASM stack, yield to JS,
+     * and then rewind when called again. This is the key to DO compatibility:
+     * it allows JS to drive the QEMU loop without blocking the DO's event loop.
+     */
+    emscripten_sleep(timeout_ms);
+
+    /* Non-blocking poll after sleep */
+    ret = qemu_poll_ns((GPollFD *)gpollfds->data, gpollfds->len, 0);
+
+    replay_mutex_lock();
+    qemu_mutex_lock_iothread();
+
+    glib_pollfds_poll();
+
+    g_main_context_release(context);
+
+    return ret;
+}
+#else
 static int os_host_main_loop_wait(int64_t timeout)
 {
     GMainContext *context = g_main_context_default();
@@ -316,6 +370,7 @@ static int os_host_main_loop_wait(int64_t timeout)
 
     return ret;
 }
+#endif /* !__EMSCRIPTEN__ */
 #else
 /***********************************************************/
 /* Polling handling */
